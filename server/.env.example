PORT=3001

# 로그인 토큰 서명용 비밀키 (반드시 설정. 미설정 시 서버가 시작되지 않음)
# 생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# 토스플레이스 웹훅 시크릿 (나중에 설정)
TOSS_WEBHOOK_SECRET=your_webhook_secret

# 이메일 알림 설정 (Gmail 기준)
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
EMAIL_TO=alert@gmail.com
