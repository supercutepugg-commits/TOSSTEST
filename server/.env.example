PORT=3001

# 로그인 토큰 서명용 비밀키 (반드시 설정. 미설정 시 서버가 시작되지 않음)
# 생성 예: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# 토스플레이스 웹훅 시크릿 (나중에 설정)
TOSS_WEBHOOK_SECRET=your_webhook_secret

# 토스페이먼츠 결제 연동 (발주 대금 결제) — 시크릿 키는 절대 외부 노출 금지
# https://developers.tosspayments.com 에서 상점 등록 후 발급
TOSS_SECRET_KEY=test_sk_...

# 토스플레이스 매출 동기화용 키 (위 토스페이먼츠 키와는 별개 — docs.tossplace.com 발급)
TOSS_PLACE_ACCESS_KEY=
TOSS_PLACE_SECRET_KEY=
